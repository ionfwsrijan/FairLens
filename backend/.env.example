# Used by deployment platforms that inject PORT dynamically.
PORT=8000
FAIRLENS_ROOT=.
FRONTEND_ORIGINS=http://localhost:3000

# Optional: Google AI Studio Gemini API free-tier key for /api/report?use_ai=true.
# Leave unset to use the deterministic local report generator.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
